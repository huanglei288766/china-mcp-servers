# ─── 飞书 MCP ─────────────────────────────────────────
# 在飞书开放平台 (https://open.feishu.cn) 创建企业自建应用获取
FEISHU_APP_ID=cli_xxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 钉钉 MCP（模式一：群机器人 Webhook）──────────────
# 在钉钉群设置 → 智能群助手 → 添加机器人获取
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxxxxxxx
DINGTALK_WEBHOOK_SECRET=SECxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 钉钉 MCP（模式二：企业内部应用）──────────────────
# 在钉钉开放平台 (https://open.dingtalk.com) 创建应用获取
DINGTALK_APP_KEY=your-app-key
DINGTALK_APP_SECRET=your-app-secret
DINGTALK_AGENT_ID=your-agent-id
